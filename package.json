{
  "name": "@xcvzmoon/kickstart-nuxt",
  "private": true,
  "description": "My nuxt starter template",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "fmt": "oxfmt && oxfmt --check",
    "lint": "oxlint",
    "typecheck": "nuxt typecheck",
    "prepare": "husky",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.101",
    "@nuxt/hints": "1.0.3",
    "@nuxt/ui": "4.6.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "nuxt": "^4.4.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.2",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "playwright-core": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,html,css,yml}": "oxfmt",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@latest"
    }
  }
}
