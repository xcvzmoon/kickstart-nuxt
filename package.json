{
  "name": "@xcvzmoon/kickstart-nuxt",
  "description": "My nuxt starter template",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "format": "prettier . --write --ignore-path .prettierignore",
    "lint": "oxlint . --fix -D correctness --ignore-path .gitignore"
  },
  "dependencies": {
    "@nuxt/eslint": "1.11.0",
    "@nuxt/ui": "4.2.1",
    "@tailwindcss/vite": "^4.1.17",
    "eslint": "^9.39.1",
    "nuxt": "npm:nuxt-nightly@4.2.2-29404491.1c73525a",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.77",
    "@prettier/plugin-oxc": "^0.1.2",
    "oxlint": "^1.31.0",
    "prettier": "3.7.3",
    "prettier-plugin-tailwindcss": "0.7.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@latest"
    }
  },
  "packageManager": "pnpm@10.24.0"
}
